// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "commonjs"
}

generator jsonTypes {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "postgresql"
}

enum VisibilityStatus {
  PUBLIC
  PRIVATE
  HIDDEN
}

enum ItemType {
  DRAFT
  RECORD
}

enum FileType {
  IMAGE
  PDF
  UNKNOWN
}

model Draft {
  id               String           @id @default(cuid())
  visibilityStatus VisibilityStatus
  /// [RecordMetadata]
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdByUserId  String
  updatedByUserId  String?
  fileAttachments  FileAttachment[]

  @@map("drafts")
}

model Record {
  id               String           @id @default(cuid())
  visibilityStatus VisibilityStatus
  /// [RecordMetadata]
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdByUserId  String
  updatedByUserId  String?
  fileAttachments  FileAttachment[]

  @@map("records")
}

model FileAttachment {
  id            String   @id @default(cuid())
  draft_id      String?
  record_id     String?
  draft         Draft?   @relation(fields: [draft_id], references: [id], onDelete: Cascade)
  record        Record?  @relation(fields: [record_id], references: [id], onDelete: Cascade)
  fileType      FileType
  originalFid   String
  extractedText String?
  filename      String
  mimeType      String
  sizeBytes     Int
  textExtracted Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([draft_id])
  @@index([record_id])
  @@map("file_attachments")
}

model ItemRelation {
  parentId   String
  parentType ItemType
  childId    String
  childType  ItemType
  createdAt  DateTime @default(now())

  @@id([parentId, childId])
  @@index([parentId, parentType])
  @@index([childId, childType])
  @@map("item_relations")
}
